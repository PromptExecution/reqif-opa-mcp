        <SPEC-OBJECT IDENTIFIER="REQ-OWASP-ASVS-007">
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>SPEC-TYPE-OWASP-ASVS</SPEC-OBJECT-TYPE-REF>
          </TYPE>
          <VALUES>
            <ATTRIBUTE-VALUE-STRING>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>ATTR-DEF-KEY</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
              <THE-VALUE>V8-3-1</THE-VALUE>
            </ATTRIBUTE-VALUE-STRING>
