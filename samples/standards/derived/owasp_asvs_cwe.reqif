        <SPEC-OBJECT IDENTIFIER="REQ-OWASP-ASVS-002">
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>SPEC-TYPE-OWASP-ASVS</SPEC-OBJECT-TYPE-REF>
          </TYPE>
          <VALUES>
            <ATTRIBUTE-VALUE-STRING>
              <DEFINITION>
