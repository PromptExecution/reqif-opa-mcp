              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>ATTR-DEF-CONTROL-ID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
              <THE-VALUE>V5.2.1</THE-VALUE>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>ATTR-DEF-SOURCE-STANDARD</ATTRIBUTE-DEFINITION-STRING-REF>
